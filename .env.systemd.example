# ClawMax full real daily pipeline environment for systemd user timer.
# Copy this file to `.env.systemd` and fill local secrets.
# Never commit `.env.systemd` or real credentials.

WECHAT_MP_APPID=your_wechat_mp_appid
WECHAT_MP_APPSECRET=your_wechat_mp_appsecret

# Optional but recommended for real-source search and image generation.
# Keep these aligned with your local proxy if you use Clash Verge / verge-mihomo.
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897
ALL_PROXY=socks5://127.0.0.1:7897

# Optional: add other model/provider keys here only if your Hermes runtime
# or custom providers require process-level environment variables.
# OPENAI_API_KEY=your_openai_api_key
